                      00001 ; CECYT 9 JUAN DE DIOS BATIZ.
                      00002 ;
                      00003 ; PRACTICA 0';.
                      00004 ; MANEJO DE UN LED OSCILANDO A 1 Hz.
                      00005 ;
                      00006 ; EQUIPO:       GRUPO: 6IMX.
                      00007 ;
                      00008 ; INTEGRANTES:
                      00009 ; 1.-RAMIREZ PACHECO.
                      00010 ; 2.-RAMIREZ ESTRADA.
                      00011 ; 3.-VEGA ALTAMIRANO.
                      00012 ; 4.-YASKAWA SANCHEZ.
                      00013 ;
                      00014 ; FECHA DE ENTREGA DEL REPORTE.
                      00015 ;
                      00016 ; ESTE PROGRAMA CONTROLA UN LED HACIENDOLO OSCILAR A UNA
                      00017 ; FRECUENCIA DE UN SEGUNDO, UTILIZANDO
                      00018 ; INTERRUPCIONES CON EL TMR0.
                      00019 ;
                      00020 ;--------------------------------------------------------------------------------------------------
                      00021  LIST   P=16F877A;
                      00022  
                      00023  ;#include "C:\Program Files (x86)\Microchip\MPASM Suite\P16F877A.INC";
                      00024  #INCLUDE "C:\Program Files\Microchip\MPASM Suite\P16F877A.INC";
                      00001         LIST
                      00002 ; P16F877A.INC  Standard Header File, Version 1.00    Microchip Technology, Inc.
                      00400         LIST
                      00025 
                      00026  
2007   3F39           00027  __CONFIG _CP_OFF & _WDT_OFF & _BODEN_OFF & _PWRTE_OFF & _XT_OSC & _WRT_OFF & _LVP_OFF & _CPD_OFF;
                      00028 ;--------------------------------------------------------------------------------------------------
                      00029 ;
                      00030 ; Fosc = 4 MHz.
                      00031 ; Ciclo de trabajo del PIC = (1/fosc)*4 = 1 µs.
                      00032 ; T int =(256-tmr0)*(P)*((1/4000000)*4) = 1 ms. // Tiempo de interrupción.
                      00033 ; tmr0=131, P=8.
                      00034 ; frec int = 1/ t int = 1 KHz.
                      00035 ;----------------------------------------------------------------------------------------------------
                      00036 ;
                      00037 ;Def. de variables del programa en RAM.
                      00038 
  00000020            00039 RESP_W                  EQU 0X20;
  00000021            00040 RESP_STATUS     EQU 0X21;
  00000022            00041 RES_PCLATH              EQU 0X22;
  00000023            00042 RES_FSR                 EQU 0X23;
  00000024            00043 PRESC_1                 EQU 0X24; .001 100 5
  00000025            00044 PRESC_2                 EQU 0X25; t int = t intb * presc_1 * presc_2
  00000026            00045 BANDERAS                EQU 0X26;
  00000027            00046 CONT_MILIS              EQU 0X27;
                      00047 
                      00048 ;---------------------------------------------------------------------------------------------------
                      00049 ; Def. de constantes a utilizar.
  00000083            00050 TMB     EQU     .131;
