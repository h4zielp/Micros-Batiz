                      00022 ;--------------------------------------------------------------------------------------------------
                      00023 ;
                      00024 ; Fosc = 4 MHz.
                      00025 ; Ciclo de trabajo del PIC = (1/fosc)*4 = 1 µs.
                      00026 ; T int =(256-tmr0)*(P)*((1/4000000)*4) = 1 ms. // Tiempo de interrupción.
                      00027 ; tmr0=131, P=8.
                      00028 ; frec int = 1/ t int = 1 KHz.
                      00029 ;----------------------------------------------------------------------------------------------------
                      00030 ;
                      00031 ;Def. de variables del programa en RAM.
                      00032 
