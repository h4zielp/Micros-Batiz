                      00023 ;--------------------------------------------------------------------------------------------------
                      00024 ;
                      00025 ; Fosc = 4 MHz.
                      00026 ; Ciclo de trabajo del PIC = (1/fosc)*4 = 1 ďż˝s.
                      00027 ; T int =(256-tmr0)*(P)*((1/4000000)*4) = 1 ms. // Tiempo de interrupciďż˝n.
                      00028 ; tmr0=131, P=8.
                      00029 ; frec int = 1/ t int = 1 KHz.
                      00030 ;----------------------------------------------------------------------------------------------------
                      00031 ;
                      00032 ;Def. de variables del programa en RAM.
